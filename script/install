#!/usr/bin/env bash
set -euo pipefail

# Install all packages declared in this repo's Brewfile.
# Usage: script/install

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${HERE}/.." && pwd)"
BREWFILE_PATH="${REPO_ROOT}/Brewfile"
TAP_NAME="grantbirki/tap"

if ! command -v brew >/dev/null 2>&1; then
  echo "Homebrew is not installed. See https://brew.sh/ to install it first." >&2
  exit 1
fi

if [ ! -f "${BREWFILE_PATH}" ]; then
  echo "Brewfile not found at ${BREWFILE_PATH}." >&2
  exit 1
fi

echo "Using Brewfile: ${BREWFILE_PATH}"

echo "Tapping ${TAP_NAME} (if not already tapped)..."
brew tap "${TAP_NAME}"

echo "Updating Homebrew..."
brew update

echo "Installing packages from Brewfile..."
brew bundle install --file="${BREWFILE_PATH}"

echo "Install complete. Run 'brew update' and 'brew upgrade' periodically to keep packages current."
